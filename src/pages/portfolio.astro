---
import Layout from '../layouts/layout.astro';
const title = 'Domen Koder | Software Dev';
const description =
	'Domen Koder is a software engineering student with a passion for web development and Linux. Explore projects and connect online.';
const canonical = 'https://domenkoder.com/portfolio';

const projects = [
	{
		title: 'Personal Portfolio Website',
		description: "The site you're on right now.",
		image: '/projects/personal-website.png',
		alt: 'Personal website project',
		href: 'https://github.com/ThatKoalaGuy/personal-website',
		stack: ['Astro', 'Tailwind CSS'],
	},
	{
		title: 'PGD Tolmin',
		description: 'Website for the Tolmin Volunteer Fire Department.',
		image: '/projects/pgd-tolmin.si.png',
		alt: 'Website for the Tolmin Volunteer FD',
		href: 'https://github.com/ThatKoalaGuy/pgd-tolmin.si',
		stack: ['Astro', 'Tailwind CSS'],
	},
	{
		title: 'Rayforge',
		description: 'A simple raycaster.',
		image: '/projects/rayforge.png',
		alt: 'Rayforger project',
		href: 'https://github.com/ThatKoalaGuy/Rayforge',
		stack: ['C++'],
	},
	{
		title: 'ToDoCLI',
		description: 'A minimal CLI todo app.',
		image: '/projects/todocli.png',
		alt: 'ToDoCLI project',
		href: 'https://github.com/ThatKoalaGuy/ToDoCLI',
		stack: ['C'],
	},
	{
		title: 'Calculator',
		description: 'A calculator built to practice web dev fundamentals.',
		image: '/projects/calculator.png',
		alt: 'Calculator project',
		href: 'https://github.com/ThatKoalaGuy/Calculator',
		stack: ['HTML', 'CSS', 'JavaScript'],
	},
	{
		title: 'Rock Paper Scissors',
		description: 'A classic game built while learning web development.',
		image: '/projects/rps.png',
		alt: 'Rock Paper Scissors project',
		href: 'https://github.com/ThatKoalaGuy/RockPaperScissors',
		stack: ['HTML', 'CSS', 'JavaScript'],
	},
];
---

<Layout {title} {description} {canonical}>
	<main class="max-w-7xl mx-auto px-4 sm:px-6 py-10 space-y-10">
		<h1 class="text-4xl sm:text-5xl font-bold text-center text-white">
			Projects
		</h1>

		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
			{
				projects.map(({ title, description, image, alt, href, stack }) => (
					<a
						href={href}
						target="_blank"
						rel="noopener noreferrer"
						class="group flex flex-col bg-zinc-700/60 border border-zinc-600/50 rounded-xl overflow-hidden shadow-lg hover:border-zinc-400/50 hover:shadow-zinc-700/30 hover:-translate-y-1 transition-all duration-300"
					>
						<div class="aspect-[3/2] overflow-hidden">
							<img
								src={image}
								alt={alt}
								class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-500"
							/>
						</div>
						<div class="flex flex-col gap-3 p-4 flex-grow">
							<h2 class="text-white font-semibold text-lg leading-snug">
								{title}
							</h2>
							<p class="text-slate-300 text-sm leading-relaxed flex-grow">
								{description}
							</p>
							<ul class="flex flex-wrap gap-2">
								{stack.map((tech) => (
									<li class="bg-slate-700/60 border border-slate-500/50 text-slate-200 text-xs font-medium px-3 py-1 rounded-full">
										{tech}
									</li>
								))}
							</ul>
						</div>
					</a>
				))
			}
		</div>
	</main>
</Layout>
