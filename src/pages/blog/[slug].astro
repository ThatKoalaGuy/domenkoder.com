---
import Layout from '../../layouts/layout.astro';
type PostModule = {
	default: any;
	meta: {
		title: string;
		date: string;
		summary?: string;
		author?: string;
		[key: string]: any;
	};
};

const modules: Record<string, PostModule> = import.meta.glob(
	'../../posts/*.mdx',
	{ eager: true },
) as Record<string, PostModule>;

export async function getStaticPaths() {
	const mods: Record<string, PostModule> = import.meta.glob(
		'../../posts/*.mdx',
		{ eager: true },
	) as Record<string, PostModule>;
	return Object.entries(mods).map(([path]) => ({
		params: { slug: path.split('/').pop()?.replace('.mdx', '')! },
	}));
}

const { slug } = Astro.params;
const postModule = Object.entries(modules).find(
	([path]) => path.split('/').pop()?.replace('.mdx', '') === slug,
)?.[1];

if (!postModule) {
	Astro.response.status = 404;
	return;
}

const { default: Post, meta } = postModule;
const canonical = `https://domenkoder.com/blog/${slug}`;
---

<Layout title={meta.title} description={meta.summary ?? ''} {canonical}>
	<main class="max-w-4xl mx-auto px-4 py-10 w-full space-y-10">
		<!-- Header -->
		<div class="border-b border-slate-600 pb-6 space-y-3">
			<h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight">
				{meta.title}
			</h1>
			<div class="flex items-center gap-4 text-slate-400 text-sm">
				<time>{meta.date}</time>
				{meta.author && <span>By {meta.author}</span>}
			</div>
		</div>

		<!-- Content -->
		<div class="prose prose-invert prose-lg max-w-none">
			<Post />
		</div>

		<!-- Back link -->
		<div class="border-t border-slate-600 pt-6">
			<a
				href="/blog"
				class="text-green-400 hover:text-white transition-colors duration-200 text-sm"
			>
				← Back to Blog
			</a>
		</div>

		<!-- Comments -->
		<div>
			<script
				src="https://giscus.app/client.js"
				data-repo="ThatKoalaGuy/domenkoder.com"
				data-repo-id="R_kgDOPL6q1Q"
				data-category="Giscuss"
				data-category-id="DIC_kwDOPL6q1c4CtebQ"
				data-mapping="pathname"
				data-strict="0"
				data-reactions-enabled="1"
				data-emit-metadata="0"
				data-input-position="top"
				data-theme="noborder_dark"
				data-lang="en"
				data-loading="lazy"
				crossorigin="anonymous"
				async></script>
		</div>
	</main>
</Layout>
