---
import Layout from '../layouts/layout.astro';
const title = 'Page Not Found | Domen Koder';
const description = "Oops! The page you're looking for doesn't exist.";
---

<Layout {title} {description}>
	<main
		class="flex flex-col justify-center items-center text-center min-h-[calc(100vh-13rem)] px-4 space-y-4"
	>
		<h1 class="text-9xl font-bold text-green">404</h1>
		<p class="text-4xl sm:text-5xl text-white">Page not found</p>
		<p class="text-2xl sm:text-3xl text-zinc-400">
			The page ran away. Probably scared of your code ;)
		</p>
		<a
			href="/"
			class="text-green-400 hover:text-white transition-colors duration-200 text-xl sm:text-2xl"
		>
			Go back home
		</a>
	</main>
</Layout>
