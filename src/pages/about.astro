---
import Layout from '../layouts/layout.astro';
const title = 'About me | Domen Koder';
const description = "A short summary of Domen Koder's interests.";
const canonical = 'https://domenkoder.com/about';

const interests = [
	{ icon: '🖥️', label: 'Operating Systems & Linux' },
	{ icon: '🔧', label: 'Homelabbing & Networking' },
	{ icon: '⚙️', label: 'Low-level & Open Source' },
	{ icon: '🚒', label: 'Firefighting' },
	{ icon: '🎮', label: 'Gaming' },
	{ icon: '🌍', label: 'Language Learning' },
];
---

<Layout {title} {description} {canonical}>
	<main class="flex-grow max-w-4xl mx-auto px-6 py-10 space-y-12">
		<h1 class="text-4xl sm:text-5xl font-bold text-center text-white">
			About Me
		</h1>

		<!-- Intro -->
		<section class="space-y-4 text-lg leading-relaxed text-slate-200">
			<p>
				Hi, I'm Domen — a developer from Slovenia 🇸🇮. I started out with HTML,
				CSS, and JavaScript, and gradually went deeper: Java, TypeScript, C++,
				Linux, and eventually the infrastructure layer — networking, self-hosted
				services, and edge computing with Cloudflare.
			</p>
			<p>
				I'm drawn to understanding how things actually work, not just how to use
				them. That means poking at operating systems, reading about low-level
				internals, and building projects that push past tutorials.
			</p>
		</section>

		<!-- Currently working on / learning -->
		<section>
			<h2
				class="text-xl font-semibold text-white border-b border-slate-600 pb-2 mb-4"
			>
				Currently
			</h2>
			<ul class="space-y-2 text-slate-200 text-lg">
				<li>🔨 Building and expanding my homelab</li>
				<li>📖 Going deeper into low-level programming and OS internals</li>
				<li>🌍 Improving my German (currently A2)</li>
			</ul>
		</section>

		<!-- Interests -->
		<section>
			<h2
				class="text-xl font-semibold text-white border-b border-slate-600 pb-2 mb-4"
			>
				Interests
			</h2>
			<ul class="grid grid-cols-2 sm:grid-cols-3 gap-3">
				{
					interests.map(({ icon, label }) => (
						<li class="flex items-center gap-3 bg-slate-700/60 border border-slate-500/50 rounded-lg px-4 py-3 text-slate-100 text-sm font-medium">
							<span class="text-xl">{icon}</span>
							{label}
						</li>
					))
				}
			</ul>
		</section>
	</main>
</Layout>
