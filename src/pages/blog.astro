---
import Layout from '../layouts/layout.astro';

const title = 'Blog | Domen Koder';
const description =
	'Explore articles by Domen Koder on programming, web development, and tech insights — a blog for curious developers.';
const canonical = 'https://domenkoder.com/blog';

const modules = import.meta.glob('../posts/*.mdx', { eager: true });
const posts = Object.entries(modules)
	.map(([path, mod]) => ({
		slug: path.split('/').pop()?.replace('.mdx', '') ?? '',
		meta: (mod as any).meta,
	}))
	.sort((a, b) => (a.meta.date < b.meta.date ? 1 : -1));
---

<Layout {title} {description} {canonical}>
	<main class="flex justify-center px-4 py-6 flex-grow">
		<div class="w-full max-w-2xl">
			<h1 class="text-5xl font-bold mb-6 text-center text-white">Blog</h1>

			<ul class="space-y-6">
				{
					posts.map(({ slug, meta }) => (
						<li>
							<a
								href={`/blog/${slug}`}
								class="block p-5 rounded-xl bg-zinc-700/60 border border-zinc-600/50 hover:border-zinc-400/50 hover:-translate-y-1 transition-all duration-300"
							>
								<div class="flex items-center justify-between gap-4 mb-2">
									<h2 class="text-lg font-semibold text-white">{meta.title}</h2>
									<time class="text-slate-400 text-sm flex-shrink-0 whitespace-nowrap">
										{meta.date}
									</time>
								</div>
								<p class="text-slate-300 text-sm leading-relaxed">
									{meta.summary ?? 'No summary available.'}
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</div>
	</main>
</Layout>
